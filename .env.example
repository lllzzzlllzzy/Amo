# ========== 必填 ==========

# PostgreSQL 密码，同时用于 db 容器初始化
POSTGRES_PASSWORD=your_strong_password

# 数据库连接地址，密码需与上面保持一致
DATABASE_URL=postgres://amo:your_strong_password@db:5432/amo

# 管理员接口认证 Token
ADMIN_TOKEN=your_admin_token

# Anthropic API 密钥
ANTHROPIC_API_KEY=your_anthropic_api_key

# ========== 可选（有默认值）==========

# 日志级别，默认 info，调试时可设为 debug
# RUST_LOG=amo=debug,tower_http=info

# LLM 提供商：anthropic 或 openai
# LLM_PROVIDER=anthropic

# Anthropic API 地址（如使用代理可修改）
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Anthropic 模型配置
# ANTHROPIC_SMART_MODEL=claude-sonnet-4-6
# ANTHROPIC_FAST_MODEL=claude-sonnet-4-6
