DATABASE_URL=postgres://user:password@localhost:5432/amo

# 管理员 token，用于调用 /admin/* 接口
ADMIN_TOKEN=your_secret_admin_token_here

# 选择 LLM 提供商: anthropic 或 openai
LLM_PROVIDER=anthropic

# Anthropic（或兼容格式的第三方代理）
# 官方：留空 ANTHROPIC_BASE_URL 即可
# 第三方代理：填入代理地址，如 https://xuedingtoken.com
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_AUTH_TOKEN=your_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_SMART_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-sonnet-4-6

# OpenAI 兼容（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_SMART_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# 服务器
HOST=0.0.0.0
PORT=3000

# =============================================================
# 前端开发提示词（开发前端时复制以下内容作为 AI 提示词使用）
# =============================================================

# ---- 用户端提示词 ----
#
# 你是一个前端开发专家，正在开发一个名为"阿默"的情感分析 Web 应用的用户端界面。
#
# 技术栈：React + TypeScript，样式使用 Tailwind CSS，状态管理使用 React hooks。
# 后端 API 地址：http://your-server:3000，接口文档见项目根目录 API.md。
#
# 产品定位：
# 面向情侣/亲密关系中有困惑的用户，提供 AI 情感分析服务。
# 整体风格温暖、亲切、不冷冰冰，像一个懂心理学的知心朋友。
# 主色调建议：温暖的粉紫色系（如 #F9A8D4 / #C084FC），避免冷色调。
#
# 页面结构（共 4 个页面）：
#
# 1. 卡密输入页（/）
#    - 居中卡片，输入框让用户输入卡密（格式 AMO-XXXX-XXXX-XXXX）
#    - 点击"开始使用"调用 POST /cards/verify 验证
#    - 验证成功：将卡密存入 localStorage key=amo_card_code，跳转主页
#    - 验证失败：展示"卡密无效或已过期"提示
#    - 页面底部说明如何购买卡密（咸鱼搜索"阿默情感分析"）
#
# 2. 主页（/home）
#    - 顶部展示剩余额度（调用 GET /cards/balance）
#    - 三个功能入口卡片：
#      ① 聊天记录分析（消耗 20 credits）- 核心功能，重点突出
#      ② 情绪疏导（消耗 2 credits/轮）
#      ③ 冲突分析（消耗 8 credits）
#    - 点击功能卡片跳转对应页面
#    - 右上角"退出"按钮，清除 localStorage 跳转卡密输入页
#    - 余额展示格式：
#      "剩余额度：150 点"
#      下方小字说明各功能消耗：聊天记录分析 20点/次 · 冲突分析 8点/次 · 情绪疏导 2点/轮
#
# 3. 聊天记录分析页（/analysis）
#    分两个阶段：
#
#    阶段一：输入
#    - 可选填写关系背景（自己姓名/年龄/备注、对方姓名/年龄/备注、关系现状）
#    - 逐条输入对话：左右两列分别代表"我说的"和"对方说的"
#      点击对应列的"+"按钮添加一条消息，可删除，可拖拽排序
#    - 底部展示已输入条数和剩余额度
#    - 点击"开始分析"调用 POST /analysis，进入阶段二
#
#    阶段二：报告展示
#    - 分析中：展示加载动画和进度提示（"正在分析情绪轨迹..."等）
#      每 3 秒轮询 GET /analysis/:task_id
#    - 分析完成后，分 5 个卡片模块展示报告：
#      ① 情绪轨迹：时间轴展示每条消息的情绪，标注转折点，附 summary
#      ② 沟通模式：依恋风格标签（焦虑型/回避型等）+ 权力结构 + 失效模式 + summary
#      ③ 风险标注：若有风险，用颜色标签展示（低=黄/中=橙/高=红），点击展开证据和解释；无风险显示"未发现明显风险"
#      ④ 核心诉求：双栏对比（我 vs 对方），各展示表面诉求和深层需求
#      ⑤ 建议：卡片列表，每条显示情境、原话→改写、理由
#    - 报告底部提供追问输入框，调用 POST /analysis/followup（SSE 流式）
#
# 4. 情绪疏导页（/emotional）
#    - 聊天气泡界面，顶部显示"阿默在线"
#    - 用户输入消息，点击发送调用 POST /emotional/chat（SSE 流式）
#    - AI 回复以流式方式逐字显示在气泡中
#    - 前端维护 history 数组，每轮对话后追加
#    - 底部输入框 + 发送按钮，发送中禁用输入
#
# 5. 冲突分析页（/conflict）
#    - 顶部可选填写背景信息（文本框）
#    - 主体是大文本框，让用户描述冲突经过（最多 2000 字，显示字数）
#    - 点击"开始分析"调用 POST /conflict/analyze（SSE 流式）
#    - 分析结果以流式方式展示在下方
#
# 通用要求：
# - 所有请求统一封装，自动携带 Authorization 头，401 时清除 localStorage 跳转首页
# - 402（额度不足）时弹出提示"额度不足，请购买新卡密"，不自动跳转
# - SSE 必须用 fetch + ReadableStream 实现，不能用 EventSource（不支持自定义请求头）
# - 移动端优先，响应式布局
# - 加载状态、错误状态都要有对应的 UI 反馈
#
# ---- 管理员端提示词 ----
#
# 你是一个前端开发专家，正在开发"阿默"情感分析应用的管理员后台界面。
#
# 技术栈：React + TypeScript，样式使用 Tailwind CSS。
# 后端 API 地址：http://your-server:3000，接口文档见项目根目录 API.md。
#
# 管理员后台只有一个页面（/admin），包含以下功能：
#
# 1. 登录验证
#    - 进入页面先弹出输入框，要求输入 Admin Token
#    - 如果已经登录之后，刷新页面需要保持登录状态
#    - 将 token 存入 sessionStorage key=amo_admin_token
#    - 所有请求携带 X-Admin-Token 头，401 时清除 token 重新要求输入
#
# 2. 生成卡密区域
#    - 表单：数量（1-100）、每张额度（下拉：30/150/400 或自定义）、过期时间（可选日期选择器）
#    - 点击"生成"调用 POST /admin/cards
#    - 生成成功后展示卡密列表，提供"一键复制全部"按钮
#    - 额度参考提示：30 credits ≈ 9.9元，150 credits ≈ 29.9元，400 credits ≈ 59.9元
#
# 3. 卡密列表区域
#    - 调用 GET /admin/cards 获取所有卡密
#    - 表格展示：卡密码、剩余额度、初始额度、已使用、创建时间、过期时间
#    - 已使用进度条（used/total）
#    - 支持按"已使用比例"排序
#    - 页面加载时自动刷新，生成新卡密后也自动刷新
#
# 通用要求：
# - 简洁实用风格，与DESIGN.md中定义的风格一致
# - 移动端和PC端都需要可用

